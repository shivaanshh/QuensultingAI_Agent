# ---- Database ----
# Defaults to a local SQLite file. Point this at a Postgres URL later with
# no code changes required (e.g. postgresql://user:pass@host/dbname).
DATABASE_URL=sqlite:///./data/tenants.db

# ---- RetellAI ----
RETELL_API_KEY=your-retell-api-key
RETELL_API_BASE=https://api.retellai.com
# Public URL this backend is reachable at (used to build each tenant's tool
# webhook URLs when provisioning a new Retell agent).
BACKEND_BASE_URL=https://your-backend.onrender.com

# ---- Google Sheets (shared service account; each tenant supplies its own
# spreadsheet ID in its tenant row if it wants a Sheets export -- optional) ----
BOOKINGS_WORKSHEET=Bookings
# Supply the service-account key EITHER as a file path (local dev)...
GOOGLE_CREDENTIALS_FILE=google-credentials.json
# ...OR paste the whole key JSON into one line (best for cloud hosts like
# Render/Railway that can't hold an uploaded file). If set, this wins.
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...",...}

# ---- Email (SMTP) -- one shared sending identity for all tenants in v1.
# For Gmail use an App Password, not your login password. ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-platform-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
FROM_EMAIL=your-platform-email@gmail.com
