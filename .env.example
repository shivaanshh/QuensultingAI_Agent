# ---- Clinic ----
CLINIC_NAME=QuensultingAI Dental Clinic
CLINIC_TIMEZONE=Asia/Kolkata
OPEN_HOUR=9
CLOSE_HOUR=18

# ---- Webhook security ----
# Any random string. Append it to the tool URLs in Retell as ?token=THIS_VALUE
WEBHOOK_SECRET=change-me-to-a-long-random-string

# ---- Google Sheets ----
# The long ID from the sheet URL: docs.google.com/spreadsheets/d/<THIS_ID>/edit
GOOGLE_SHEETS_ID=
BOOKINGS_WORKSHEET=Bookings
# Supply the service-account key EITHER as a file path (local dev)...
GOOGLE_CREDENTIALS_FILE=google-credentials.json
# ...OR paste the whole key JSON into one line (best for cloud hosts like
# Render/Railway that can't hold an uploaded file). If set, this wins.
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...",...}

# ---- Email (SMTP). For Gmail use an App Password, not your login password. ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-clinic-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
FROM_EMAIL=your-clinic-email@gmail.com
CLINIC_INBOX=frontdesk@quensultingai.com

# ---- Optional outbound webhook (fires on every successful booking) ----
# BOOKING_WEBHOOK_URL=https://your-n8n-or-zapier-hook
